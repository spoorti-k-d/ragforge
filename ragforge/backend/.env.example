# RAG Forge — Environment Configuration
# Copy this file to .env and fill in your values

# ─── LLM ──────────────────────────────────────────────────────────────────────
# Get your free Groq API key at: https://console.groq.com/
GROQ_API_KEY=your_groq_api_key_here

# ─── Security ─────────────────────────────────────────────────────────────────
# Any long random string — used for JWT signing
# Generate one with: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your_secret_key_here_generate_a_random_64char_string

# ─── Database ─────────────────────────────────────────────────────────────────
# SQLite path — use an absolute path to avoid CWD issues
# Replace /absolute/path/to with the actual path where you cloned the repo
DATABASE_URL=sqlite+aiosqlite:////absolute/path/to/rag-forge-osc/ragforge/backend/ragforge.db

# ─── Optional Settings ────────────────────────────────────────────────────────
# JWT token expiry in minutes (default: 30)
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Refresh token expiry in days (default: 7)
REFRESH_TOKEN_EXPIRE_DAYS=7

# OTP expiry in minutes (default: 10)
OTP_EXPIRE_MINUTES=10
